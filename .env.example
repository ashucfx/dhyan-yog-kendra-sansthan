# This project uses server-side Supabase access via /api/join.
# Do not expose service role key in frontend code.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
ADMIN_ACCESS_KEY=your-strong-admin-password

# Preferred for your use case (Gmail alerts, no domain purchase)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=dhyanvedaglobal@gmail.com
SMTP_PASS=your-gmail-app-password

# Optional fallback provider
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
NOTIFICATION_EMAIL_TO=dhyanvedaglobal@gmail.com
NOTIFICATION_EMAIL_FROM=Dhyan Yog Kendra <alerts@yourdomain.com>

# Only needed if you later switch to direct browser Supabase usage:
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
