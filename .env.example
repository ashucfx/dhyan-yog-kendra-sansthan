SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
ADMIN_ACCESS_KEY=your-strong-admin-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=dhyanvedaglobal@gmail.com
SMTP_PASS=your-gmail-app-password
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
NOTIFICATION_EMAIL_TO=dhyanvedaglobal@gmail.com
NOTIFICATION_EMAIL_FROM=dhyanvedaglobal@gmail.com
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_ENVIRONMENT=sandbox
SHIPROCKET_EMAIL=ops@example.com
SHIPROCKET_PASSWORD=your-shiprocket-password
SHADOWFAX_QUOTE_URL=https://your-shadowfax-adapter.example.com/quote
SHADOWFAX_ORDER_URL=https://your-shadowfax-adapter.example.com/order
SHADOWFAX_TRACK_URL=https://your-shadowfax-adapter.example.com/track
SHADOWFAX_API_TOKEN=your-shadowfax-bearer-token
SHADOWFAX_API_KEY=your-shadowfax-api-key
SHADOWFAX_API_SECRET=your-shadowfax-api-secret
SHADOWFAX_PICKUP_POSTAL_CODE=127021
SHADOWFAX_DEFAULT_WEIGHT_KG=0.5
SHADOWFAX_DEFAULT_LENGTH_CM=20
SHADOWFAX_DEFAULT_BREADTH_CM=15
SHADOWFAX_DEFAULT_HEIGHT_CM=10
SUPABASE_REVIEW_MEDIA_BUCKET=review-media

# Notes:
# - NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY are required for frontend auth.
# - SUPABASE_SERVICE_ROLE_KEY must remain server-only.
# - Create a public Supabase storage bucket named "products" before using admin image uploads.
# - Create a public Supabase storage bucket named "review-media" before enabling customer review photo/video uploads.
# - SHADOWFAX_QUOTE_URL: called at checkout to get live shipping rates.
# - SHADOWFAX_ORDER_URL: called by admin after payment capture to create an AWB and schedule pickup.
# - SHADOWFAX_TRACK_URL: base URL for tracking; AWB is appended as a path segment (e.g. /track/{awb}).
# - All three Shadowfax endpoints are optional. Omitting them activates the built-in pincode-zone fallback.
